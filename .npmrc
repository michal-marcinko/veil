# Required because @umbra-privacy/web-zk-prover@2.0.1 declares a peer
# dep on @umbra-privacy/sdk@2.0.3 but the project tracks sdk@2.1.1.
# Without this flag, every fresh `npm install` errors with ERESOLVE.
# Remove once Umbra ships a web-zk-prover release that accepts >=2.1.x.
legacy-peer-deps=true
