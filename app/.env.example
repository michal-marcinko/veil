# Network — "devnet" or "mainnet"
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# RPC endpoints (must match the network above)
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_RPC_WSS_URL=wss://api.devnet.solana.com

# Invoice registry program (anchor program ID, devnet default)
NEXT_PUBLIC_INVOICE_REGISTRY_PROGRAM_ID=54ryi8hcihut8fDSVFSbN5NbArQ5GAd1xgmGCA3hqWoo

# Payment mint (Circle's devnet USDC by default)
# Mainnet USDC: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
NEXT_PUBLIC_PAYMENT_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Umbra services (devnet defaults; switch to mainnet endpoints when going live)
# Mainnet:  https://utxo-indexer.api.umbraprivacy.com / https://relayer.api.umbraprivacy.com
NEXT_PUBLIC_UMBRA_INDEXER_API=https://utxo-indexer.api-devnet.umbraprivacy.com
NEXT_PUBLIC_UMBRA_RELAYER_API=https://relayer.api-devnet.umbraprivacy.com

# Optional — set to "1" to enable verbose console logging in client code
NEXT_PUBLIC_VEIL_DEBUG=

# Optional — public site URL used for OG image resolution.
# On Vercel, omit and the framework's VERCEL_URL fallback handles it.
NEXT_PUBLIC_SITE_URL=

# Server-only — Bundlr funding key (base58 encoded private key)
# Get this by funding a Solana keypair and exporting its private key.
# DO NOT commit this value.
BUNDLR_PRIVATE_KEY=
